            "direct store mutation bypasses Save changes",
            "empty principal list"
          ]
        },
        "evidence": {
          "artifact_type": "video",
          "required_capture": true
        },
        "cases": [
          {
            "start_ref": "desktop_admin_governance_editable",
            "action": {
              "actor": "playwright_user",
